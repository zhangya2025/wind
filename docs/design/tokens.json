{
  "meta": {
    "purpose": "Phase 0 SSOT tokens for visual imitation of seatosummit.com with current WINDHARD baseline.",
    "mapping": {
      "theme.settings.layout.contentSize": "layout.contentSize",
      "theme.settings.layout.wideSize": "layout.wideSize",
      "theme.settings.custom.windhard.layout.containerMax": "layout.containerMax",
      "theme.settings.custom.windhard.layout.containerPadding": "layout.containerPadding",
      "theme.settings.spacing.spacingSizes": "spacing.themeSpacingSizes",
      "theme.settings.custom.windhard.spacing.section": "spacing.section",
      "theme.settings.custom.windhard.spacing.sectionTight": "spacing.sectionTight",
      "theme.settings.color.palette": "color.paletteMirror",
      "theme.settings.custom.windhard.radius.button": "radius.button",
      "theme.styles.elements.button": "components.button.baseBehaviorReference",
      "theme.styles.elements.heading": "typography.headingDefaults"
    },
    "source": "wp-content/themes/windhard/theme.json"
  },
  "typography": {
    "fontFamilies": {
      "sans": "Inter, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif",
      "display": "Inter, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif",
      "mono": "\"Fira Code\", monospace"
    },
    "fontWeights": {
      "light": 200,
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "black": 900
    },
    "fontSizes": {
      "h1": "clamp(2.15rem, 4.8vw, 3rem)",
      "h2": "clamp(1.75rem, 3.5vw, 2rem)",
      "h3": "clamp(1.125rem, 2.4vw, 1.375rem)",
      "h4": "clamp(1rem, 2vw, 1.125rem)",
      "h5": "0.875rem",
      "h6": "0.875rem",
      "body": "1rem",
      "bodyLarge": "1.125rem",
      "caption": "0.875rem",
      "button": "1rem"
    },
    "lineHeights": {
      "heading": 1.125,
      "body": 1.6,
      "caption": 1.4,
      "button": 1.2
    },
    "letterSpacing": {
      "heading": "-0.1px",
      "h5": "0.5px",
      "h6": "1.4px",
      "body": "0",
      "button": "0"
    },
    "headingDefaults": {
      "fontWeight": 400,
      "lineHeight": 1.125,
      "letterSpacing": "-0.1px"
    }
  },
  "color": {
    "neutralScale": {
      "0": "#FFFFFF",
      "50": "#FBFAF8",
      "100": "#F5F4F1",
      "200": "#E9E7E2",
      "300": "#D8D5CF",
      "400": "#B7B3AA",
      "500": "#8D897F",
      "600": "#68645C",
      "700": "#4A463F",
      "800": "#2D2A26",
      "900": "#111111"
    },
    "paletteMirror": {
      "base": "#FFFFFF",
      "contrast": "#111111",
      "accent-1": "#FFEE58",
      "accent-2": "#F6CFF4",
      "accent-3": "#503AA8",
      "accent-4": "#686868",
      "accent-5": "#FBFAF3",
      "accent-6": "color-mix(in srgb, currentColor 20%, transparent)"
    },
    "semantic": {
      "bg": "#FFFFFF",
      "surface": "#FBFAF3",
      "text": "#111111",
      "muted": "#686868",
      "border": "#D8D5CF",
      "accent": "#111111",
      "accentHover": "color-mix(in srgb, #111111 85%, transparent)",
      "focus": "#686868"
    }
  },
  "layout": {
    "contentSize": "645px",
    "wideSize": "1340px",
    "containerMax": "1200px",
    "containerPadding": "clamp(1rem, 2vw, 2rem)"
  },
  "spacing": {
    "scale": {
      "0": "0",
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "5": "20px",
      "6": "24px",
      "8": "32px",
      "10": "40px",
      "12": "48px",
      "16": "64px",
      "20": "80px"
    },
    "themeSpacingSizes": {
      "20": "10px",
      "30": "20px",
      "40": "30px",
      "50": "clamp(30px, 5vw, 50px)",
      "60": "clamp(30px, 7vw, 70px)",
      "70": "clamp(50px, 7vw, 90px)",
      "80": "clamp(70px, 10vw, 140px)"
    },
    "section": "clamp(2.5rem, 5vw, 5rem)",
    "sectionTight": "clamp(1.5rem, 3vw, 3rem)",
    "gap": {
      "xs": "10px",
      "sm": "20px",
      "md": "30px",
      "lg": "clamp(30px, 5vw, 50px)"
    }
  },
  "radius": {
    "button": "999px",
    "card": "16px",
    "input": "12px"
  },
  "border": {
    "width": "1px",
    "color": "#D8D5CF"
  },
  "shadow": {
    "cardHover": "0 8px 24px rgba(17, 17, 17, 0.08)"
  },
  "components": {
    "button": {
      "baseBehaviorReference": {
        "paddingY": "1rem",
        "paddingX": "2.25rem",
        "focusOutlineOffset": "2px"
      }
    }
  }
}
